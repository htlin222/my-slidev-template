        <mxCell id="eligibility-header" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3d6869;strokeColor=none;fontColor=#ffffff;fontStyle=1;fontSize=26;align=center;verticalAlign=middle;" value="Key Eligibility Criteria" vertex="1">
