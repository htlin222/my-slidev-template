        <mxCell id="eligibility-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=18;fontColor=#000000;spacing=0;spacingTop=6;spacingLeft=8;spacingRight=8;" value="&amp;bull; &lt;b&gt;Residual invasive disease in the breast and/or axillary&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;b&gt;lymph nodes&lt;/b&gt; after neoadjuvant chemotherapy with&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;HER2-directed therapy (NAT)&lt;sup&gt;a&lt;/sup&gt;&lt;br&gt;&amp;bull; &lt;b&gt;High-risk defined as presentation prior to NAT with:&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;#9702; &lt;b&gt;Inoperable eBC (cT4,N0-3,M0 or cT1-3,N2-3,M0)&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;b&gt;OR&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;#9702; &lt;b&gt;Operable eBC (cT1-3,N0-1,M0) with axillary&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;b&gt;node-positive disease (ypN1-3) after NAT&lt;/b&gt;&lt;br&gt;&amp;bull; &lt;b&gt;Centrally confirmed HER2+&lt;/b&gt; (IHC 3+ or ISH+) eBC&lt;br&gt;&amp;bull; ECOG PS 0 or 1" vertex="1">
